<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile — Uponthee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/output.css" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }
    .field { width:100%; border:1px solid #e5e7eb; border-radius:12px; padding:11px 14px; font-size:13px; font-family:'DM Sans',sans-serif; color:#111827; background:#fafaf9; transition:border-color 0.2s,box-shadow 0.2s,background 0.2s; outline:none; box-sizing:border-box; }
    .field[readonly], .field:disabled { background:#fafaf9; color:#6b7280; cursor:default; }
    .field:not([readonly]):not(:disabled):focus { border-color:#55142A; box-shadow:0 0 0 3px rgba(85,20,42,0.08); background:white; }
    select.field:disabled { appearance:none; }
    textarea.field { resize:vertical; min-height:80px; }
    .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(80px); background:#111; color:#fff; padding:12px 20px; border-radius:12px; font-size:13px; z-index:100; opacity:0; transition:transform 0.3s cubic-bezier(0.22,1,0.36,1),opacity 0.3s; white-space:nowrap; }
    .toast.show { transform:translateX(-50%) translateY(0); opacity:1; }
    .toast.success { background:#166534; }
    .toast.error { background:#991b1b; }
  </style>
</head>
<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <main class="mx-auto max-w-6xl px-5 py-8 lg:py-10">

    <!-- Back -->
    <a href="/home" class="mb-6 inline-flex items-center gap-2 text-sm text-gray-500 transition hover:text-[#55142A]">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      Back to home
    </a>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[280px_1fr] lg:gap-8">

      <!-- LEFT — Avatar card -->
      <div class="flex flex-col items-center rounded-[22px] border border-black/[0.06] bg-white p-6 text-center shadow-[0_2px_16px_rgba(0,0,0,0.04)]">

        <!-- Avatar -->
        <div class="relative mb-4">
          <div class="h-28 w-28 overflow-hidden rounded-full border-[3px] border-white shadow-[0_4px_16px_rgba(0,0,0,0.12)]">
            <img id="avatar-img" src="<%= typeof user !== 'undefined' && user.avatar ? user.avatar : '/images/default-avatar.svg' %>" alt="Profile photo" class="h-full w-full object-cover" />
          </div>
          <label for="avatar-input" class="absolute bottom-0 right-0 flex h-8 w-8 cursor-pointer items-center justify-center rounded-full border-2 border-white bg-[#55142A]">
            <svg class="h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0zM18.75 10.5h.008v.008h-.008V10.5z"/></svg>
          </label>
          <input type="file" id="avatar-input" accept="image/*" class="hidden" onchange="previewAvatar(this)" />
        </div>

        <h2 class="mb-1 text-xl font-medium text-gray-900" style="font-family:'Cormorant Garamond',serif;">
          <%= typeof user !== 'undefined' ? user.first_name + ' ' + user.last_name : 'Your Name' %>
        </h2>
        <p class="mb-5 text-sm text-gray-400"><%= typeof user !== 'undefined' ? user.email : 'email@example.com' %></p>

        <!-- Meta -->
        <div class="w-full space-y-2.5 border-t border-gray-100 pt-4 text-left">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-400">Account status</span>
            <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Active</span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-400">Member since</span>
            <span class="font-medium text-gray-700"><%= typeof user !== 'undefined' && user.created_at ? new Date(user.created_at).toLocaleDateString('en-GB',{month:'short',year:'numeric'}) : 'Jan 2026' %></span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-400">Bookings</span>
            <span class="font-medium text-gray-700"><%= typeof user !== 'undefined' && user.bookings_count ? user.bookings_count : 0 %></span>
          </div>
        </div>

        <!-- Quick links -->
        <div class="mt-5 w-full space-y-1 border-t border-gray-100 pt-4">
          <% [
            { href:'/bookings', label:'My Bookings', path:'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25' },
            { href:'/saved',    label:'Saved Lodges', path:'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z' },
            { href:'/settings', label:'Settings', path:'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z' },
          ].forEach(function(link) { %>
          <a href="<%= link.href %>" class="flex items-center gap-2.5 rounded-xl px-3 py-2.5 text-sm text-gray-700 transition hover:bg-[#f8f6f3]">
            <svg class="h-3.5 w-3.5 text-[#55142A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="<%= link.path %>"/></svg>
            <%= link.label %>
          </a>
          <% }); %>
        </div>
      </div>

      <!-- RIGHT — Info form -->
      <div class="rounded-[22px] border border-black/[0.06] bg-white p-6 shadow-[0_2px_16px_rgba(0,0,0,0.04)] lg:p-8">

        <div class="mb-6 flex items-start justify-between">
          <div>
            <h3 class="text-2xl font-medium text-gray-900" style="font-family:'Cormorant Garamond',serif;">Personal information</h3>
            <p class="mt-1 text-xs text-gray-400">Update your profile details</p>
          </div>
          <button id="edit-btn" onclick="toggleEdit()" class="flex items-center gap-1.5 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm text-gray-600 transition hover:bg-gray-50">
            <svg id="edit-icon" class="h-3.5 w-3.5 text-[#55142A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
            <span id="edit-label">Edit profile</span>
          </button>
        </div>

        <form id="profile-form" action="/profile/update" method="post" class="grid grid-cols-1 gap-5 sm:grid-cols-2">

          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">First name</label>
            <input type="text" name="first_name" value="<%= typeof user !== 'undefined' ? user.first_name : '' %>" readonly class="field" id="f-first_name" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Last name</label>
            <input type="text" name="last_name" value="<%= typeof user !== 'undefined' ? user.last_name : '' %>" readonly class="field" id="f-last_name" />
          </div>
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Email address</label>
            <input type="email" name="email" value="<%= typeof user !== 'undefined' ? user.email : '' %>" readonly class="field" id="f-email" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Phone number</label>
            <input type="tel" name="phone" value="<%= typeof user !== 'undefined' && user.phone ? user.phone : '' %>" readonly class="field" id="f-phone" placeholder="08012345678" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Date of birth</label>
            <input type="date" name="dob" value="<%= typeof user !== 'undefined' && user.dob ? user.dob : '' %>" readonly class="field" id="f-dob" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Gender</label>
            <select name="gender" disabled class="field" id="f-gender">
              <option value="">Select</option>
              <option value="male" <%= typeof user !== 'undefined' && user.gender === 'male' ? 'selected' : '' %>>Male</option>
              <option value="female" <%= typeof user !== 'undefined' && user.gender === 'female' ? 'selected' : '' %>>Female</option>
            </select>
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Location</label>
            <input type="text" name="location" value="<%= typeof user !== 'undefined' && user.location ? user.location : '' %>" readonly class="field" id="f-location" placeholder="e.g. Umuchima, Owerri" />
          </div>
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400">Bio</label>
            <textarea name="bio" readonly class="field" id="f-bio" placeholder="Tell us a bit about yourself..."><%= typeof user !== 'undefined' && user.bio ? user.bio : '' %></textarea>
          </div>
          <div id="save-row" class="hidden items-center justify-end gap-3 sm:col-span-2">
            <button type="button" onclick="toggleEdit()" class="rounded-xl border border-gray-200 bg-white px-5 py-2.5 text-sm text-gray-600 transition hover:bg-gray-50">Cancel</button>
            <button type="submit" id="save-btn" class="rounded-xl bg-[#55142A] px-6 py-2.5 text-sm font-medium text-white transition hover:bg-[#6e1a35]">Save changes</button>
          </div>

        </form>
      </div>

    </div>
  </main>

  <div class="toast" id="toast"></div>

  <%- include('partials/footer.ejs') %>
  <script src="/js/navbar.js"></script>
  <script src="/js/profile.js"></script>
</body>
</html>
