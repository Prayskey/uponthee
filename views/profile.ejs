<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile — Uponthee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/output.css" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }
    .field {
      width: 100%; border: 1px solid #e5e7eb; border-radius: 12px;
      padding: 11px 14px; font-size: 13px; font-family: 'DM Sans', sans-serif;
      color: #111827; background: #fafaf9; transition: border-color 0.2s, box-shadow 0.2s, background 0.2s; outline: none;
      box-sizing: border-box;
    }
    .field[readonly], .field:disabled { background: #fafaf9; color: #6b7280; cursor: default; }
    .field:not([readonly]):not(:disabled):focus { border-color: #55142A; box-shadow: 0 0 0 3px rgba(85,20,42,0.08); background: white; }
    select.field:disabled { appearance: none; }
    textarea.field { resize: vertical; min-height: 80px; }
    .label { display: block; font-size: 11px; font-weight: 500; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .card { background: white; border: 1px solid rgba(0,0,0,0.06); border-radius: 22px; padding: 28px; box-shadow: 0 2px 16px rgba(0,0,0,0.04); }
    .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px); background: #111; color: #fff; padding: 12px 20px; border-radius: 12px; font-size: 13px; z-index: 100; opacity: 0; transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), opacity 0.3s; white-space: nowrap; }
    .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
    .toast.success { background: #166534; }
    .toast.error { background: #991b1b; }
  </style>
</head>

<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <main style="max-width:1100px; margin:0 auto; padding:32px 20px 80px;">

    <!-- Back -->
    <a href="/home" style="display:inline-flex;align-items:center;gap:8px;font-size:13px;color:#6b7280;text-decoration:none;margin-bottom:24px;transition:color 0.2s;" onmouseover="this.style.color='#55142A'" onmouseout="this.style.color='#6b7280'">
      <svg style="width:15px;height:15px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      Back to home
    </a>

    <div style="display:grid; grid-template-columns:300px 1fr; gap:28px; align-items:start;">

      <!-- LEFT — Avatar card -->
      <div class="card" style="display:flex; flex-direction:column; align-items:center; text-align:center;">

        <!-- Avatar -->
        <div style="position:relative; margin-bottom:16px;">
          <div style="width:110px;height:110px;border-radius:50%;overflow:hidden;border:3px solid white;box-shadow:0 4px 16px rgba(0,0,0,0.12);">
            <img id="avatar-img" src="<%= typeof user !== 'undefined' && user.avatar ? user.avatar : '/images/default-avatar.svg' %>" alt="Profile photo" style="width:100%;height:100%;object-fit:cover;" />
          </div>
          <label for="avatar-input" style="position:absolute;bottom:0;right:0;width:30px;height:30px;border-radius:50%;background:#55142A;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid white;">
            <svg style="width:13px;height:13px;color:white;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0zM18.75 10.5h.008v.008h-.008V10.5z"/></svg>
          </label>
          <input type="file" id="avatar-input" accept="image/*" style="display:none;" onchange="previewAvatar(this)" />
        </div>

        <h2 style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:#111827;margin-bottom:4px;">
          <%= typeof user !== 'undefined' ? user.first_name + ' ' + user.last_name : 'Your Name' %>
        </h2>
        <p style="font-size:13px;color:#9ca3af;margin-bottom:20px;">
          <%= typeof user !== 'undefined' ? user.email : 'email@example.com' %>
        </p>

        <div style="width:100%;border-top:1px solid #f3f4f6;padding-top:16px;display:flex;flex-direction:column;gap:10px;text-align:left;">
          <div style="display:flex;justify-content:space-between;font-size:13px;">
            <span style="color:#9ca3af;">Account status</span>
            <span style="color:#166534;font-weight:500;background:#dcfce7;padding:2px 10px;border-radius:999px;font-size:12px;">Active</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:13px;">
            <span style="color:#9ca3af;">Member since</span>
            <span style="color:#374151;font-weight:500;">
              <%= typeof user !== 'undefined' && user.created_at ? new Date(user.created_at).toLocaleDateString('en-GB',{month:'short',year:'numeric'}) : 'Jan 2026' %>
            </span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:13px;">
            <span style="color:#9ca3af;">Bookings</span>
            <span style="color:#374151;font-weight:500;"><%= typeof user !== 'undefined' && user.bookings_count ? user.bookings_count : 0 %></span>
          </div>
        </div>

        <!-- Quick links -->
        <div style="width:100%;margin-top:20px;border-top:1px solid #f3f4f6;padding-top:16px;display:flex;flex-direction:column;gap:6px;">
          <a href="/bookings" style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:13px;color:#374151;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='#f8f6f3'" onmouseout="this.style.background='transparent'">
            <svg style="width:14px;height:14px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25"/></svg>
            My Bookings
          </a>
          <a href="/saved" style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:13px;color:#374151;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='#f8f6f3'" onmouseout="this.style.background='transparent'">
            <svg style="width:14px;height:14px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
            Saved Lodges
          </a>
          <a href="/settings" style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;font-size:13px;color:#374151;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='#f8f6f3'" onmouseout="this.style.background='transparent'">
            <svg style="width:14px;height:14px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/></svg>
            Settings
          </a>
        </div>

      </div>

      <!-- RIGHT — Info form -->
      <div class="card">

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
          <div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;color:#111827;">Personal information</h3>
            <p style="font-size:12px;color:#9ca3af;margin-top:3px;">Update your profile details</p>
          </div>
          <button id="edit-btn" onclick="toggleEdit()" style="display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:10px;border:1px solid #e5e7eb;background:white;font-size:13px;color:#374151;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background 0.15s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='white'">
            <svg id="edit-icon" style="width:13px;height:13px;color:#55142A;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
            <span id="edit-label">Edit profile</span>
          </button>
        </div>

        <form id="profile-form" action="/profile/update" method="post" style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">

          <div>
            <label class="label">First name</label>
            <input type="text" name="first_name" value="<%= typeof user !== 'undefined' ? user.first_name : '' %>" readonly class="field" id="f-first_name" />
          </div>

          <div>
            <label class="label">Last name</label>
            <input type="text" name="last_name" value="<%= typeof user !== 'undefined' ? user.last_name : '' %>" readonly class="field" id="f-last_name" />
          </div>

          <div style="grid-column:1/-1;">
            <label class="label">Email address</label>
            <input type="email" name="email" value="<%= typeof user !== 'undefined' ? user.email : '' %>" readonly class="field" id="f-email" />
          </div>

          <div>
            <label class="label">Phone number</label>
            <input type="tel" name="phone" value="<%= typeof user !== 'undefined' && user.phone ? user.phone : '' %>" readonly class="field" id="f-phone" placeholder="08012345678" />
          </div>

          <div>
            <label class="label">Date of birth</label>
            <input type="date" name="dob" value="<%= typeof user !== 'undefined' && user.dob ? user.dob : '' %>" readonly class="field" id="f-dob" />
          </div>

          <div>
            <label class="label">Gender</label>
            <select name="gender" disabled class="field" id="f-gender">
              <option value="" <%= !user || !user.gender ? 'selected' : '' %>>Select</option>
              <option value="male"   <%= typeof user !== 'undefined' && user.gender === 'male'   ? 'selected' : '' %>>Male</option>
              <option value="female" <%= typeof user !== 'undefined' && user.gender === 'female' ? 'selected' : '' %>>Female</option>
            </select>
          </div>

          <div>
            <label class="label">Location</label>
            <input type="text" name="location" value="<%= typeof user !== 'undefined' && user.location ? user.location : '' %>" readonly class="field" id="f-location" placeholder="e.g. Umuchima, Owerri" />
          </div>

          <div style="grid-column:1/-1;">
            <label class="label">Bio</label>
            <textarea name="bio" readonly class="field" id="f-bio" placeholder="Tell us a bit about yourself..."><%= typeof user !== 'undefined' && user.bio ? user.bio : '' %></textarea>
          </div>

          <!-- Save button (hidden until edit mode) -->
          <div style="grid-column:1/-1; display:none; justify-content:flex-end; gap:10px;" id="save-row">
            <button type="button" onclick="toggleEdit()" style="padding:10px 20px;border-radius:10px;border:1px solid #e5e7eb;background:white;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;color:#374151;">Cancel</button>
            <button type="submit" style="padding:10px 24px;border-radius:10px;background:#55142A;color:white;border:none;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;" id="save-btn">Save changes</button>
          </div>

        </form>
      </div>

    </div>
  </main>

  <div class="toast" id="toast"></div>

  <%- include('partials/footer.ejs') %>

  <script src="/js/navbar.js"></script>
  <script src="/js/profile.js"></script>
</body>
</html>
