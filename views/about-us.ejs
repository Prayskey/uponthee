<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Uponthee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link href="/src/output.css" rel="stylesheet" />
  <link rel="stylesheet" href="/src/navbar.css" />
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #f8f6f3; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    .fade-up { opacity: 0; }
    .fade-up.visible { animation: fadeUp 0.55s cubic-bezier(0.22,1,0.36,1) forwards; }
    .delay-1 { animation-delay: 80ms; }
    .delay-2 { animation-delay: 160ms; }
    .delay-3 { animation-delay: 240ms; }
  </style>
</head>
<body class="min-h-screen pt-16">

  <%- include('partials/header.ejs') %>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-[#55142A] px-6 pb-24 pt-20 text-center">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,rgba(255,255,255,0.04)_0%,transparent_60%)]"></div>
    <div class="relative mx-auto max-w-2xl">
      <p class="fade-up mb-4 text-xs font-medium uppercase tracking-[0.2em] text-[#A79A79]">About Uponthee</p>
      <h1 class="fade-up delay-1 mb-5 text-4xl font-medium leading-tight text-white sm:text-5xl" style="font-family:'Cormorant Garamond',serif;">
        Built for FUTO students finding better places to live
      </h1>
      <p class="fade-up delay-2 mx-auto max-w-lg text-[15px] leading-relaxed text-white/65">
        Uponthee removes the stress from finding student accommodation around FUTO — replacing scattered information with clarity, trust, and speed.
      </p>
    </div>
  </section>

  <main class="mx-auto max-w-5xl px-6 pb-20">

    <!-- Stats -->
    <div class="fade-up -mt-10 mb-18 grid grid-cols-2 gap-4 md:grid-cols-4">
      <% [
        { target: 1200, suffix: '+', label: 'Lodges listed' },
        { target: 8500, suffix: '+', label: 'Students helped' },
        { target: 32,   suffix: '+', label: 'Communities' },
        { target: 99,   suffix: '%', label: 'Satisfaction rate' },
      ].forEach(function(s) { %>
      <div class="group rounded-[20px] border border-black/[0.06] bg-white p-6 text-center transition duration-200 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(85,20,42,0.08)]">
        <p class="text-[36px] font-medium text-[#55142A]" style="font-family:'Cormorant Garamond',serif;">
          <span class="count-up" data-target="<%= s.target %>">0</span><%= s.suffix %>
        </p>
        <p class="mt-1 text-[13px] text-gray-500"><%= s.label %></p>
      </div>
      <% }); %>
    </div>

    <!-- Highlights -->
    <div class="mb-20 grid gap-5 md:grid-cols-3">
      <% [
        { icon:'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z', title:'Faster discovery', desc:'Find available lodges around your campus without stress or delay. Browse by community, price, or amenities in seconds.' },
        { icon:'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z', title:'Verified listings', desc:"Every lodge is curated to reduce misinformation. You won't waste time on fake listings or unreliable contacts." },
        { icon:'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z', title:'Student-centered', desc:'Built specifically for the FUTO community. Every feature is designed with student needs and budgets in mind.' },
      ].forEach(function(card, i) { %>
      <div class="fade-up <%= i > 0 ? 'delay-'+i : '' %> rounded-[20px] border border-black/[0.06] bg-white p-7 transition duration-200 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.07)]">
        <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#55142A]/[0.07]">
          <svg class="h-5 w-5 text-[#55142A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="<%= card.icon %>"/></svg>
        </div>
        <h3 class="mb-2 text-base font-medium text-gray-900"><%= card.title %></h3>
        <p class="text-[13px] leading-[1.7] text-gray-500"><%= card.desc %></p>
      </div>
      <% }); %>
    </div>

    <!-- Story -->
    <div class="fade-up mb-20 grid items-center gap-14 md:grid-cols-2">
      <div>
        <p class="mb-3 text-[11px] font-medium uppercase tracking-[0.15em] text-[#A79A79]">Our story</p>
        <h2 class="mb-5 text-3xl font-medium leading-snug text-gray-900" style="font-family:'Cormorant Garamond',serif;">Why we built Uponthee</h2>
        <p class="mb-4 text-sm leading-[1.8] text-gray-600">Finding accommodation around FUTO has always been stressful — scattered information, unreliable contacts, and wasted time knocking on doors. Students deserved better.</p>
        <p class="text-sm leading-[1.8] text-gray-600">We built Uponthee to fix that. One platform that organizes everything clearly: verified listings, real photos, honest pricing, and direct booking — all without the confusion.</p>
      </div>
      <div class="flex aspect-[4/3] items-center justify-center overflow-hidden rounded-[20px] border border-black/[0.06] bg-white">
        <div class="p-8 text-center text-gray-400">
          <svg class="mx-auto mb-3 h-12 w-12 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor"/><path stroke-linecap="round" d="m21 15-5-5L5 21"/></svg>
          <p class="text-sm">Campus illustration</p>
        </div>
      </div>
    </div>

    <!-- Values -->
    <div class="fade-up mb-8 text-center">
      <p class="mb-3 text-[11px] font-medium uppercase tracking-[0.15em] text-[#A79A79]">What we stand for</p>
      <h2 class="text-3xl font-medium text-gray-900" style="font-family:'Cormorant Garamond',serif;">Our values</h2>
    </div>
    <div class="mb-20 grid gap-5 md:grid-cols-3">
      <% [
        { title:'Trust', desc:'Every listing is curated to reduce misinformation and risk for students.', accent:'#55142A' },
        { title:'Simplicity', desc:'Clean flows, fewer steps, faster decisions. No complexity for its own sake.', accent:'#A79A79' },
        { title:'Accessibility', desc:'Built so every student — regardless of budget — can find good accommodation.', accent:'#55142A' },
      ].forEach(function(v, i) { %>
      <div class="fade-up <%= i > 0 ? 'delay-'+i : '' %> rounded-r-[20px] border-l-[3px] border-l-[<%= v.accent %>] bg-white p-7 border border-black/[0.06]" style="border-left-color:<%= v.accent %>">
        <h3 class="mb-2 text-base font-medium text-gray-900"><%= v.title %></h3>
        <p class="text-[13px] leading-[1.7] text-gray-500"><%= v.desc %></p>
      </div>
      <% }); %>
    </div>

    <!-- CTA -->
    <div class="fade-up rounded-3xl bg-[#55142A] px-10 py-14 text-center">
      <h2 class="mb-3 text-3xl font-medium text-white" style="font-family:'Cormorant Garamond',serif;">Start exploring lodges around FUTO</h2>
      <p class="mx-auto mb-7 max-w-md text-sm text-white/65">Join thousands of students already using Uponthee to find better, safer accommodation.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/lodges" class="inline-block rounded-xl bg-white px-7 py-3 text-sm font-medium text-[#55142A] transition hover:scale-[1.03]">Explore lodges</a>
        <a href="/sign-up" class="inline-block rounded-xl border border-white/20 bg-white/12 px-7 py-3 text-sm font-medium text-white transition hover:scale-[1.03]">Create account</a>
      </div>
    </div>

  </main>

  <%- include('partials/footer.ejs') %>

  <script src="/js/navbar.js"></script>
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    function countUp(el) {
      const target = parseInt(el.dataset.target), duration = 1200, start = performance.now();
      function update(now) {
        const p = Math.min((now - start) / duration, 1);
        el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target).toLocaleString();
        if (p < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }
    const countObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.querySelectorAll('.count-up').forEach(countUp); countObs.unobserve(e.target); } });
    }, { threshold: 0.3 });
    document.querySelectorAll('.count-up').forEach(el => countObs.observe(el.closest('div') || el));
  </script>
</body>
</html>
