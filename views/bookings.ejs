<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Bookings</title>

    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/src/output.css" />

    <style>
      body {
        font-family: "DM Sans", sans-serif;
      }
    </style>
  </head>

  <body class="min-h-screen bg-gray-50">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <!-- HEADER -->
      <div class="mb-10 flex items-end justify-between">
        <div>
          <h1 class="text-3xl font-semibold text-gray-900">My Bookings</h1>
          <p class="mt-1 text-sm text-gray-500">Manage and track your stays</p>
        </div>

        <a
          href="/"
          class="text-sm text-gray-500 transition hover:text-gray-900"
        >
          Home
        </a>
      </div>

      <!-- STATS -->
      <div class="mb-10 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-gray-100 bg-white p-4">
          <p class="text-xs text-gray-400 uppercase">Total</p>
          <p id="stat-total" class="mt-1 text-xl font-semibold">—</p>
        </div>

        <div class="rounded-xl border border-gray-100 bg-white p-4">
          <p class="text-xs text-gray-400 uppercase">Upcoming</p>
          <p
            id="stat-upcoming"
            class="mt-1 text-xl font-semibold text-green-600"
          >
            —
          </p>
        </div>

        <div class="rounded-xl border border-gray-100 bg-white p-4">
          <p class="text-xs text-gray-400 uppercase">Completed</p>
          <p id="stat-completed" class="mt-1 text-xl font-semibold">—</p>
        </div>

        <div class="rounded-xl border border-gray-100 bg-white p-4">
          <p class="text-xs text-gray-400 uppercase">Spent</p>
          <p id="stat-spent" class="mt-1 text-xl font-semibold">—</p>
        </div>
      </div>

      <!-- FILTER -->
      <div class="mb-8 flex flex-wrap gap-2">
        <button
          class="active rounded-full border bg-gray-900 px-4 py-1.5 text-sm text-white filter"
          data-filter="all"
        >
          All
        </button>
        <button
          class="rounded-full border px-4 py-1.5 text-sm text-gray-600 filter"
          data-filter="confirmed"
        >
          Confirmed
        </button>
        <button
          class="rounded-full border px-4 py-1.5 text-sm text-gray-600 filter"
          data-filter="pending"
        >
          Pending
        </button>
        <button
          class="rounded-full border px-4 py-1.5 text-sm text-gray-600 filter"
          data-filter="completed"
        >
          Completed
        </button>
      </div>

      <!-- LIST -->
      <div id="bookings-list" class="space-y-5"></div>

      <!-- EMPTY -->
      <div id="empty-state" class="hidden py-24 text-center">
        <p class="text-lg font-semibold text-gray-800">No bookings yet</p>
        <p class="mt-1 text-sm text-gray-500">Start exploring lodges</p>
      </div>
    </main>

    <!-- MODAL -->
    <div
      id="modal"
      class="fixed inset-0 hidden items-center justify-center bg-black/40"
    >
      <div class="w-full max-w-md rounded-xl bg-white p-6">
        <h3 class="mb-3 text-lg font-semibold">Cancel booking?</h3>
        <p class="mb-5 text-sm text-gray-500">This action cannot be undone.</p>

        <div class="flex gap-3">
          <button
            id="confirmCancel"
            class="flex-1 rounded-lg bg-red-600 py-2 text-white"
          >
            Cancel Booking
          </button>
          <button id="closeModal" class="flex-1 rounded-lg border py-2">
            Close
          </button>
        </div>
      </div>
    </div>

    <script>
      const BOOKINGS_DATA = [
        {
          id: 1,
          name: "Emerald Lodge",
          location: "FUTO",
          date: "2026-04-20",
          price: 120000,
          status: "confirmed",
          image: "/images/lodge1.jpg",
        },
        {
          id: 2,
          name: "Palm Hostel",
          location: "Ihiagwa",
          date: "2026-03-10",
          price: 90000,
          status: "completed",
          image: "/images/lodge2.jpg",
        },
      ];
    </script>

    <script src="/js/bookings-page.js"></script>
  </body>
</html>
